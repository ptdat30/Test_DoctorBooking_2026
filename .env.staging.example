# ══════════════════════════════════════════════════════════════
# .env.staging — Staging Environment Variables
# Copy from .env.staging.example and fill in actual values
# ══════════════════════════════════════════════════════════════

# ── Database (Aiven Cloud — staging database) ─────────────────
DB_URL=jdbc:mysql://your-aiven-host:port/doctor_booking_staging?useSSL=true&requireSSL=true
DB_USERNAME=avnadmin

# ── Ports ─────────────────────────────────────────────────────
BACKEND_PORT=8080
FRONTEND_PORT=80

# ── Frontend API Target ───────────────────────────────────────
VITE_API_TARGET=http://backend:8080
