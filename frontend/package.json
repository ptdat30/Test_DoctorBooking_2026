{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "e2e": "codeceptjs run --steps --config codecept.conf.cjs",
    "e2e:bva": "codeceptjs run --config codecept.conf.cjs --grep @bva",
    "e2e:smoke": "codeceptjs run --config codecept.conf.cjs --grep @smoke",
    "e2e:headless": "cross-env HEADLESS=true codeceptjs run --steps --config codecept.conf.cjs",
    "e2e:parallel": "cross-env HEADLESS=true codeceptjs run-workers 2 --config codecept.conf.cjs",
    "e2e:report": "allure generate e2e/output/allure-results --clean -o e2e/output/allure-report && allure open e2e/output/allure-report"
  },
  "dependencies": {
    "axios": "1.15.2",
    "clsx": "^2.1.1",
    "feather-icons": "^4.29.2",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.555.0",
    "moment": "^2.30.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.1",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.4",
    "react-toastify": "^11.0.5",
    "recharts": "^3.5.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@codeceptjs/allure-legacy": "^1.0.2",
    "@codeceptjs/configure": "^0.10.0",
    "@eslint/js": "^9.36.0",
    "@faker-js/faker": "^9.9.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "allure-commandline": "^2.43.0",
    "allure-js-commons": "^3.10.1",
    "autoprefixer": "^10.4.22",
    "codeceptjs": "^3.7.9",
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "playwright": "^1.61.1",
    "postcss": "8.5.10",
    "tailwindcss": "^3.4.18",
    "vite": "npm:rolldown-vite@7.1.14",
    "wait-on": "^7.2.0"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.1.14"
  }
}
